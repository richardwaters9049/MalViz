{
  "name": "malviz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev frontend",
    "build": "next build frontend",
    "start": "next start frontend",
    "setup": "bash scripts/dev/start-local.sh",
    "start:local": "bash scripts/dev/start-local.sh",
    "docker:dev": "docker compose --project-directory . -f infra/docker/compose.yml -f infra/docker/compose.dev.yml up --build",
    "docker:dev:down": "docker compose --project-directory . -f infra/docker/compose.yml -f infra/docker/compose.dev.yml down",
    "lint": "eslint -c config/eslint.config.mjs",
    "test": "vitest run --config config/vitest.config.ts",
    "test:python": "cd backend/worker/python && PYTHONPATH=. python3 -m pytest tests -q",
    "test:watch": "vitest --config config/vitest.config.ts",
    "db:generate": "prisma generate --config config/prisma.config.ts",
    "db:migrate": "prisma migrate dev --config config/prisma.config.ts",
    "db:seed": "tsx backend/prisma/seed.ts",
    "quarantine:prune": "tsx backend/scripts/maintenance/prune-quarantine.ts",
    "worker:python": "cd backend/worker/python && . .venv/bin/activate && python main.py"
  },
  "dependencies": {
    "@prisma/client": "6.19.1",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "bullmq": "^5.79.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-type": "^22.0.1",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
