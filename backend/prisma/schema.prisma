generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum FileStatus {
  UPLOADED
  QUEUED
  SCANNING
  CLEAN
  SUSPICIOUS
  MALICIOUS
  UNKNOWN
  FAILED
}

enum JobStatus {
  QUEUED
  SCANNING
  COMPLETED
  FAILED
}

enum Verdict {
  CLEAN
  SUSPICIOUS
  MALICIOUS
  UNKNOWN
  FAILED
}

enum IndicatorType {
  IP
  DOMAIN
  URL
  HASH
  EMAIL
  CERTIFICATE
  REGISTRY_KEY
  MUTEX
  PROCESS
  FILENAME
  FILE_PATH
  COMMAND
}

enum ArtefactType {
  FILE
  HASH
  URL
  DOMAIN
  IP
  EMAIL
  ARCHIVE
}

enum AnalysisPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum AnalysisRequestStatus {
  QUEUED
  SCANNING
  COMPLETED
  FAILED
  CANCELLED
}

enum FeedbackLabel {
  FALSE_POSITIVE
  FALSE_NEGATIVE
  CONFIRMED_MALICIOUS
  CONFIRMED_CLEAN
  NEEDS_REVIEW
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String
  role             Role              @default(USER)
  files            File[]
  artefacts        Artefact[]
  analysisRequests AnalysisRequest[]
  feedback         Feedback[]
  auditLogs        AuditLog[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("users")
}

model File {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFilename String      @map("original_filename")
  storedFilename   String      @unique @map("stored_filename")
  md5              String?
  sha1             String?
  sha256           String
  mimeType         String      @map("mime_type")
  fileSize         Int         @map("file_size")
  storagePath      String      @map("storage_path")
  status           FileStatus  @default(UPLOADED)
  scanJobs         ScanJob[]
  scanResult       ScanResult?
  indicators       Indicator[]
  artefact         Artefact?
  feedback         Feedback[]
  createdAt        DateTime    @default(now()) @map("created_at")
  deletedAt        DateTime?   @map("deleted_at")

  @@index([userId, createdAt])
  @@index([status])
  @@map("files")
}

model ScanJob {
  id                String           @id @default(uuid())
  fileId            String           @map("file_id")
  file              File             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  analysisRequestId String?          @unique @map("analysis_request_id")
  analysisRequest   AnalysisRequest? @relation(fields: [analysisRequestId], references: [id], onDelete: SetNull)
  status            JobStatus        @default(QUEUED)
  attempts          Int              @default(0)
  errorMessage      String?          @map("error_message")
  startedAt         DateTime?        @map("started_at")
  completedAt       DateTime?        @map("completed_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("scan_jobs")
}

model ScanResult {
  id                  String   @id @default(uuid())
  fileId              String   @unique @map("file_id")
  file                File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  verdict             Verdict
  riskScore           Int      @map("risk_score")
  summary             String
  reasons             Json     @default("[]")
  matchedRules        Json     @default("[]") @map("matched_rules")
  staticFindings      Json     @default("{}") @map("static_findings")
  dynamicFindings     Json     @default("{}") @map("dynamic_findings")
  recommendedActions  Json     @default("[]") @map("recommended_actions")
  rawReportJson       Json     @default("{}") @map("raw_report_json")
  reportSchemaVersion Int      @default(1) @map("report_schema_version")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("scan_results")
}

model Indicator {
  id                String           @id @default(uuid())
  fileId            String?          @map("file_id")
  file              File?            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  artefactId        String?          @map("artefact_id")
  artefact          Artefact?        @relation(fields: [artefactId], references: [id], onDelete: Cascade)
  analysisRequestId String?          @map("analysis_request_id")
  analysisRequest   AnalysisRequest? @relation(fields: [analysisRequestId], references: [id], onDelete: SetNull)
  type              IndicatorType
  value             String
  confidence        Int              @default(50)
  source            String
  description       String?
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([fileId, type])
  @@index([artefactId, type])
  @@index([type, value])
  @@map("indicators")
}

model Artefact {
  id               String            @id @default(uuid())
  userId           String?           @map("user_id")
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type             ArtefactType
  value            String
  displayName      String?           @map("display_name")
  fileId           String?           @unique @map("file_id")
  file             File?             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  metadata         Json              @default("{}")
  analysisRequests AnalysisRequest[]
  indicators       Indicator[]
  reputations      Reputation[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([type, value])
  @@map("artefacts")
}

model AnalysisRequest {
  id                String                @id @default(uuid())
  artefactId        String?               @map("artefact_id")
  artefact          Artefact?             @relation(fields: [artefactId], references: [id], onDelete: SetNull)
  artefactType      ArtefactType          @map("artefact_type")
  artefactReference String                @map("artefact_reference")
  submittedById     String                @map("submitted_by")
  submittedBy       User                  @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  priority          AnalysisPriority      @default(NORMAL)
  requestedModules  Json                  @default("[]") @map("requested_modules")
  status            AnalysisRequestStatus @default(QUEUED)
  scanJob           ScanJob?
  indicators        Indicator[]
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  completedAt       DateTime?             @map("completed_at")

  @@index([status, createdAt])
  @@index([submittedById, createdAt])
  @@index([artefactType, artefactReference])
  @@map("analysis_requests")
}

model MalwareFamily {
  id          String   @id @default(uuid())
  name        String   @unique
  aliases     Json     @default("[]")
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("malware_families")
}

model ThreatActor {
  id          String   @id @default(uuid())
  name        String   @unique
  aliases     Json     @default("[]")
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("threat_actors")
}

model Campaign {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  metadata    Json      @default("{}")
  firstSeen   DateTime? @map("first_seen")
  lastSeen    DateTime? @map("last_seen")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("campaigns")
}

model ThreatFeed {
  id        String   @id @default(uuid())
  name      String   @unique
  provider  String?
  enabled   Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("threat_feeds")
}

model Reputation {
  id         String    @id @default(uuid())
  artefactId String?   @map("artefact_id")
  artefact   Artefact? @relation(fields: [artefactId], references: [id], onDelete: Cascade)
  targetType String    @map("target_type")
  targetId   String    @map("target_id")
  source     String
  score      Int?
  verdict    Verdict?
  details    Json      @default("{}")
  observedAt DateTime  @default(now()) @map("observed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([artefactId])
  @@index([targetType, targetId])
  @@map("reputations")
}

model IOCRelationship {
  id               String   @id @default(uuid())
  sourceEntityType String   @map("source_entity_type")
  sourceEntityId   String   @map("source_entity_id")
  relationship     String
  targetEntityType String   @map("target_entity_type")
  targetEntityId   String   @map("target_entity_id")
  confidence       Int      @default(50)
  source           String
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sourceEntityType, sourceEntityId])
  @@index([targetEntityType, targetEntityId])
  @@map("ioc_relationships")
}

model Feedback {
  id        String        @id @default(uuid())
  fileId    String        @map("file_id")
  file      File          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     FeedbackLabel
  comment   String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([fileId])
  @@map("feedback")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("audit_logs")
}
