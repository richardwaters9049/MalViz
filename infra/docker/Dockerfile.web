FROM oven/bun:1.3.14

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1
ARG TYPST_VERSION=0.14.2

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl python3 tar xz-utils \
  && curl -fsSL "https://github.com/typst/typst/releases/download/v${TYPST_VERSION}/typst-x86_64-unknown-linux-musl.tar.xz" -o /tmp/typst.tar.xz \
  && tar -xJf /tmp/typst.tar.xz -C /tmp \
  && mv "/tmp/typst-x86_64-unknown-linux-musl/typst" /usr/local/bin/typst \
  && chmod +x /usr/local/bin/typst \
  && rm -rf /var/lib/apt/lists/* /tmp/typst.tar.xz /tmp/typst-x86_64-unknown-linux-musl

COPY package.json bun.lock tsconfig.json ./
COPY config ./config
COPY backend/lib ./backend/lib
COPY backend/prisma ./backend/prisma
COPY backend/scripts ./backend/scripts
COPY frontend ./frontend

RUN bun install --frozen-lockfile \
  && bun run db:generate \
  && bun run build

ENV NODE_ENV=production

EXPOSE 3000

CMD ["bun", "run", "start", "--", "-H", "0.0.0.0", "-p", "3000"]
