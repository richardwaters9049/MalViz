# Copy this file to infra/docker/prod.env on the server.
# Do not commit the real prod.env file.

POSTGRES_DB=malviz
POSTGRES_USER=malviz
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Use your public URL. With a real domain, Caddy will request HTTPS certificates automatically.
APP_URL=https://malviz.example.com
MALVIZ_SITE_ADDRESS=malviz.example.com

SESSION_COOKIE_NAME=malviz_session
MALVIZ_DELETED_FILE_RETENTION_DAYS=7
MAX_UPLOAD_SIZE_MB=25
MAX_UPLOAD_BYTES=26214400
WORKER_POLL_SECONDS=2
