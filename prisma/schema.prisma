generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum FileStatus {
  UPLOADED
  QUEUED
  SCANNING
  CLEAN
  SUSPICIOUS
  MALICIOUS
  UNKNOWN
  FAILED
}

enum JobStatus {
  QUEUED
  SCANNING
  COMPLETED
  FAILED
}

enum Verdict {
  CLEAN
  SUSPICIOUS
  MALICIOUS
  UNKNOWN
  FAILED
}

enum IndicatorType {
  IP
  DOMAIN
  URL
  HASH
  EMAIL
  REGISTRY_KEY
  FILE_PATH
  COMMAND
}

enum FeedbackLabel {
  FALSE_POSITIVE
  FALSE_NEGATIVE
  CONFIRMED_MALICIOUS
  CONFIRMED_CLEAN
  NEEDS_REVIEW
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  role      Role       @default(USER)
  files     File[]
  feedback  Feedback[]
  auditLogs AuditLog[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model File {
  id               String       @id @default(uuid())
  userId           String       @map("user_id")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFilename String       @map("original_filename")
  storedFilename   String       @unique @map("stored_filename")
  md5              String?
  sha1             String?
  sha256           String
  mimeType         String       @map("mime_type")
  fileSize         Int          @map("file_size")
  storagePath      String       @map("storage_path")
  status           FileStatus   @default(UPLOADED)
  scanJobs         ScanJob[]
  scanResult       ScanResult?
  indicators       Indicator[]
  feedback         Feedback[]
  createdAt        DateTime     @default(now()) @map("created_at")
  deletedAt        DateTime?    @map("deleted_at")

  @@index([userId, createdAt])
  @@index([status])
  @@map("files")
}

model ScanJob {
  id           String    @id @default(uuid())
  fileId       String    @map("file_id")
  file         File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  status       JobStatus @default(QUEUED)
  attempts     Int       @default(0)
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("scan_jobs")
}

model ScanResult {
  id                 String   @id @default(uuid())
  fileId             String   @unique @map("file_id")
  file               File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  verdict            Verdict
  riskScore          Int      @map("risk_score")
  summary            String
  reasons            Json     @default("[]")
  matchedRules       Json     @default("[]") @map("matched_rules")
  staticFindings     Json     @default("{}") @map("static_findings")
  dynamicFindings    Json     @default("{}") @map("dynamic_findings")
  recommendedActions Json     @default("[]") @map("recommended_actions")
  rawReportJson      Json     @default("{}") @map("raw_report_json")
  reportSchemaVersion Int     @default(1) @map("report_schema_version")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("scan_results")
}

model Indicator {
  id        String        @id @default(uuid())
  fileId    String        @map("file_id")
  file      File          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  type      IndicatorType
  value     String
  source    String
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([fileId, type])
  @@map("indicators")
}

model Feedback {
  id        String        @id @default(uuid())
  fileId    String        @map("file_id")
  file      File          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     FeedbackLabel
  comment   String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([fileId])
  @@map("feedback")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("audit_logs")
}
