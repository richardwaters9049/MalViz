# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.pytest_cache/
/worker/python/.pytest_cache/
.pytest_cache/

# next.js
/.next/
.next/
/out/

# production
/build
/build/
/dist/
dist/
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local quarantine storage
/storage/quarantine/
/storage/tmp/
/.malviz/
malviz-quarantine/

# python worker
/worker/python/.venv/
/worker/python/.venv/**
/worker/python/__pycache__/
__pycache__/
**/__pycache__/
*.pyc
**/*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
